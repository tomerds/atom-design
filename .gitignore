# macOS
.DS_Store

# Personal Claude Code settings (shared settings live in .claude/settings.json)
.claude/settings.local.json

# Ignore all top-level directories (project deliverables stay local)
# except the shared brand assets and Claude Code setup.
/*/
!/assets/
!/.claude/

# Exception: the finalized intro-call-deck template + its assets are shared
# (the intro-call-deck skill points at them), so track those specifically.
# One-off per-prospect decks stay local.
!/Intro_Call_Deck/
/Intro_Call_Deck/*
!/Intro_Call_Deck/Intro_Call_Deck.html
!/Intro_Call_Deck/img/

# The checkin-deck skill's reference component library lives inside the skill
# at .claude/skills/checkin-deck/references/ (tracked via the !/.claude/ rule
# above). Built partner check-in decks are deliverables and stay local.

# Python bytecode
__pycache__/
*.pyc
