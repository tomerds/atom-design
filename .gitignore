# macOS
.DS_Store

# Personal Claude Code settings (shared settings live in .claude/settings.json)
.claude/settings.local.json

# Ignore all top-level directories (project deliverables stay local)
# except the shared brand assets and Claude Code setup.
/*/
!/assets/
!/.claude/

# Exception: the finalized intro-call-deck template + its assets and worked
# example are shared (the intro-call-deck skill points at them), so track
# those specifically. One-off prospect decks and v1-v3 stay local.
!/Intro_Call_Deck/
/Intro_Call_Deck/*
!/Intro_Call_Deck/v4/
/Intro_Call_Deck/v4/*
!/Intro_Call_Deck/v4/Intro_Call_Deck.html
!/Intro_Call_Deck/v4/Intro_Call_Deck_University_of_Iowa.html
!/Intro_Call_Deck/v4/Intro_Call_Deck_University_of_Iowa.pdf
!/Intro_Call_Deck/v4/img/

# Exception: the SUNY Cortland 30-day check-in is the checkin-deck skill's
# house reference (agenda + objectives + feedback structure), so track its
# source, PDF, and logo. The regenerable per-slide PNGs stay local.
!/SUNY_Cortland_30_Day_Checkin/
/SUNY_Cortland_30_Day_Checkin/*
!/SUNY_Cortland_30_Day_Checkin/v1/
/SUNY_Cortland_30_Day_Checkin/v1/*
!/SUNY_Cortland_30_Day_Checkin/v1/SUNY_Cortland_30_Day_Checkin.html
!/SUNY_Cortland_30_Day_Checkin/v1/SUNY_Cortland_30_Day_Checkin.pdf
!/SUNY_Cortland_30_Day_Checkin/v1/cortlandlogo.png
